# OpenWeatherMap API Configuration
# Obtenir une clé gratuite: https://openweathermap.org/api
# IMPORTANT: Ne pas commiter le vrai .env avec ta clé!
OPENWEATHERMAP_API_KEY=your_api_key_here

# Supabase Configuration (profil cloud + agenda)
# Crée un projet sur https://supabase.com puis copie les clés Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
